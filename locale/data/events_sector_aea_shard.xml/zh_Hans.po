"data/events_sector_aea_shard.xml$//event[@name=\"AEA_SHARD_DRUNK\"]/choice[4]/text"
msgstr "威胁要把他的星舰炸成碎片。"

#: src-en/data/events_sector_aea_shard.xml:349
msgid ""
