#: src-en/data/text_tooltips.xml.append:1
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_aea_shields\"]"
msgstr "护盾：吸收目标系统所受的离子伤害。"

#: src-en/data/text_tooltips.xml.append:2
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_aea_shields_enemy\"]"
msgstr "护盾：吸收来自其他敌方系统的离子伤害。"

#: src-en/data/text_tooltips.xml.append:3
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_aea_super_shields\"]"
msgstr "辅助护盾：生成超级护盾层，能够阻挡所有弹丸和光束。"

#: src-en/data/text_tooltips.xml.append:4
msgid ""
"data/text_tooltips.xml.append$//text[@name=\"tooltip_aea_super_shields_enemy\"]"
msgstr "辅助护盾：生成超级护盾层，能够阻挡所有弹丸和光束。"

#: src-en/data/text_tooltips.xml.append:5
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_aea_clone_crime\"]"
msgstr "改良克隆舱：跃迁时生成伪克隆体，防止克隆体及其他带有死亡倒计时的船员因死亡倒"
"计时而死亡。"

#: src-en/data/text_tooltips.xml.append:6
msgid ""
"data/text_tooltips.xml.append$//text[@name=\"tooltip_aea_clone_crime_enemy\"]"
msgstr "改良克隆舱：跃迁时生成伪克隆体，防止克隆体及其他带有死亡倒计时的船员因死亡倒"
"计时而死亡。"

#: src-en/data/text_tooltips.xml.append:8
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_aea_acidic_nebula\"]"
msgstr "你身处一个酸性星云之中。你的传感器将无法工作，而空置的舱室会逐渐被酸性云团随"
"机侵蚀。"
