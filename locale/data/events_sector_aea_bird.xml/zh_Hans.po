"伤运输船。"

#: src-en/data/events_sector_aea_bird.xml:1360
msgid ""
"data/events_sector_aea_bird.xml$//event[@name=\"AEA_BIRD_REBEL_TRANS_DEADCREW\"]/choice/text"
msgstr "继续。"

