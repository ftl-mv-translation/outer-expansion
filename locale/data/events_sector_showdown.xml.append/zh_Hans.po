#: src-en/data/events_sector_showdown.xml.append:54
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"TRUE_VICTORY_CREW_AEA_BILL\"]/text"
msgstr "“你知道吗，一开始我甚至不知道自己是什么，那时我还天真又无知。我现在的一切，全"
"都归功于你。无论你作何选择，我都会站在你这边。”"

#: src-en/data/events_sector_showdown.xml.append:55
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"TRUE_VICTORY_CREW_AEA_BILL\"]/text-"
"aea-alternative"
msgstr "“真高兴我们能活着离开那里，有好几次都差点没挺过去。”"

#: src-en/data/events_sector_showdown.xml.append:58
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"TRUE_VICTORY_CREW_AEA_BILL\"]/choice/text"
