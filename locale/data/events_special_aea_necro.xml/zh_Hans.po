msgid ""
"data/events_special_aea_necro.xml$//textList[@name=\"TEXT_DESTROYED_AEA_NECRO\"]/text[2]"
msgstr "异教徒星舰已被摧毁。你或许已拯救了无数人类的生命，更不用说其他有机生命了。"

