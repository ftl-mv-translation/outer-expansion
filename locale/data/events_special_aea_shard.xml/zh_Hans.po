#: src-en/data/events_special_aea_shard.xml:361
msgid ""
"data/events_special_aea_shard.xml$//event[@name=\"TRANSPORT_AEA_SHARD_LOOT\"]/choice[2]/event/text"
msgstr "那艘星舰始终停在你武器射程之外，最终跃迁离去。"

#: src-en/data/events_special_aea_shard.xml:363
